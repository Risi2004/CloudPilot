# Local Ollama server URL (no trailing slash)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model tag (must be pulled locally: ollama pull qwen3:8b)
OLLAMA_MODEL=qwen3:8b

# LiteLLM provider for ADK tool-capable Ollama chat (do not change unless you know why)
OLLAMA_PROVIDER=ollama_chat

# Optional: enable LiteLLM request debug logging (true/false)
LITELLM_DEBUG=false

# Knowledge / RAG (embeddings are separate from chat model)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama
CHROMA_PERSIST_DIR=./data/chroma
VECTOR_STORE=chroma
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_CHUNK_OVERLAP=200
KNOWLEDGE_TOP_K=8
KNOWLEDGE_UPSERT_BATCH_SIZE=32
# Smaller batches + retries help remote RunPod Ollama during large syncs
EMBEDDING_REQUEST_BATCH_SIZE=2
EMBEDDING_MAX_RETRIES=6
EMBEDDING_RETRY_BASE_DELAY_SEC=3
EMBEDDING_INTER_BATCH_DELAY_SEC=1
