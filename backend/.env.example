PORT=5000
MONGO_URI=mongodb://localhost:27017/cloudpilot
JWT_SECRET=your_jwt_secret_key_here

# Cloudflare R2 Credentials (Private S3 compatible)
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=your_bucket_name

# Nodemailer SMTP Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="CloudPilot Mission Control <no-reply@cloudpilot.io>"

# Firebase Admin Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----"

# Frontend Application URL
FRONTEND_URL=http://localhost:5173

# Agent runtime (repository analysis)
AGENT_RUNTIME_PYTHON=C:\cpvenv\Scripts\python.exe
AGENT_RUNTIME_DIR=../agent-runtime
# AGENT_RUNTIME_CLI=C:\cpvenv\Scripts\cloudpilot-analyze-repo.exe
AGENT_RUNTIME_TIMEOUT_MS=600000

# Forwarded to Python agent-runtime (copy from agent-runtime/.env)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_PROVIDER=ollama_chat
GITHUB_TOKEN=
CLOUDPILOT_CLONE_DIR=

# GitHub OAuth (create app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/github/callback

# Knowledge / RAG (forwarded to agent-runtime)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama
CHROMA_PERSIST_DIR=../agent-runtime/data/chroma
VECTOR_STORE=chroma
KNOWLEDGE_SYNC_TIMEOUT_MS=1800000
PLATFORM_SELECTION_TIMEOUT_MS=600000
ARCHITECTURE_TIMEOUT_MS=600000

# Deployment agent
DEPLOYMENT_SESSION_TTL_SECONDS=7200
DEPLOYMENT_TIMEOUT_MS=120000
DEPLOYMENT_POLL_TIMEOUT_MS=30000
KNOWLEDGE_SYNC_BATCH_SIZE=25
KNOWLEDGE_UPSERT_BATCH_SIZE=32
EMBEDDING_REQUEST_BATCH_SIZE=2
EMBEDDING_MAX_RETRIES=6
EMBEDDING_RETRY_BASE_DELAY_SEC=3
EMBEDDING_INTER_BATCH_DELAY_SEC=1
