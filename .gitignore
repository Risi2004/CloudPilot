# Dependencies
node_modules/
**/node_modules/

# Environment & secrets (keep *.example files tracked)
.env
.env.*
!.env.example
!**/.env.example
/backend/.env
/backend/.env.*
!/backend/.env.example
/frontend/.env
/frontend/.env.*
!/frontend/.env.example
/agent-runtime/.env
/agent-runtime/.env.*
!/agent-runtime/.env.example

# Python / agent-runtime
/agent-runtime/.venv/
/agent-runtime/venv/
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/htmlcov/
/agent-runtime/dist/
/agent-runtime/build/
/agent-runtime/**/*.egg-info/
*.egg-info/

# Local repository clone scratch (optional)
cloudpilot-clones/
.agent-clones/

# ChromaDB vector store persistence
data/chroma/
**/data/chroma/

# Build outputs
/frontend/dist/
/frontend/dist-ssr/
/backend/dist/

# Logs
*.log
logs/
/backend/*.log
/frontend/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

